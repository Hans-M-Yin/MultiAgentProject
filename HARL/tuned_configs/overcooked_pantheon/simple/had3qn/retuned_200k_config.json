{
    "algo_args": {
        "algo": {
            "batch_size": 64,
            "buffer_size": 30000,
            "epsilon": 0.12,
            "epsilon_anneal_steps": 160000,
            "epsilon_finish": 0.15,
            "epsilon_start": 1.0,
            "fixed_order": true,
            "gamma": 0.995,
            "n_step": 3,
            "polyak": 0.005,
            "share_param": true
        },
        "device": {
            "cuda": false,
            "cuda_deterministic": true,
            "torch_threads": 4
        },
        "eval": {
            "eval_episodes": 5,
            "n_eval_rollout_threads": 1,
            "use_eval": true
        },
        "logger": {
            "log_dir": "./results"
        },
        "model": {
            "base_activation_func": "relu",
            "base_hidden_sizes": [
                128,
                128
            ],
            "critic_lr": 0.0001,
            "dueling_a_activation_func": "hardswish",
            "dueling_a_hidden_sizes": [
                128
            ],
            "dueling_v_activation_func": "hardswish",
            "dueling_v_hidden_sizes": [
                128
            ],
            "lr": 0.0001
        },
        "render": {
            "render_episodes": 10,
            "use_render": false
        },
        "seed": {
            "seed": 10,
            "seed_specify": true
        },
        "train": {
            "eval_interval": 1000,
            "log_interval": null,
            "model_dir": null,
            "n_rollout_threads": 1,
            "num_env_steps": 200000,
            "train_interval": 1,
            "update_per_train": 1,
            "use_linear_lr_decay": false,
            "use_proper_time_limits": true,
            "warmup_steps": 12000
        }
    },
    "env_args": {
        "baselines": false,
        "ego_agent_idx": 0,
        "horizon": 400,
        "layout_name": "simple",
        "state_type": "EP"
    },
    "main_args": {
        "algo": "had3qn",
        "env": "overcooked_pantheon",
        "exp_name": "retuned_had3qn_200k",
        "load_config": ""
    }
}
